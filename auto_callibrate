/*
 * 8-Channel Line Follower Robot - Auto Calibration Code
 * Sensors connected to A0 to A7
 * 
 * Functionality:
 * 1. Place robot on white surface
 * 2. Robot slowly moves forward crossing black line
 * 3. Collects raw data and auto-sets thresholds
 * 4. Displays calibrated sensor values as 0 (white) or 1 (black)
 */

// Pin definitions
const int sensorPins[8] = {A0, A1, A2, A3, A4, A5, A6, A7};
const int motorLeftForward = 22;
const int motorLeftBackward = 23;
const int motorRightForward = 24;
const int motorRightBackward = 25;

// Calibration variables
int sensorMin[8] = {1023, 1023, 1023, 1023, 1023, 1023, 1023, 1023};
int sensorMax[8] = {0, 0, 0, 0, 0, 0, 0, 0};
int threshold[8] = {0, 0, 0, 0, 0, 0, 0, 0};

// Sensor readings
int rawValue[8] = {0, 0, 0, 0, 0, 0, 0, 0};
int calibratedValue[8] = {0, 0, 0, 0, 0, 0, 0, 0};

// State variables
bool calibrated = false;
unsigned long calibrationStartTime = 0;
const unsigned long calibrationDuration = 5000; // 5 seconds calibration

void setup() {
  Serial.begin(9600);
  
  // Initialize sensor pins
  for (int i = 0; i < 8; i++) {
    pinMode(sensorPins[i], INPUT);
  }
  
  // Initialize motor pins
  pinMode(motorLeftForward, OUTPUT);
  pinMode(motorLeftBackward, OUTPUT);
  pinMode(motorRightForward, OUTPUT);
  pinMode(motorRightBackward, OUTPUT);
  
  // Stop all motors initially
  stopMotors();
  
  Serial.println("=== 8-Channel Line Follower Calibration ===");
  Serial.println("Place robot on WHITE surface");
  Serial.println("Press any key to start calibration...");
  
  while (!Serial.available()) {
    delay(100);
  }
  Serial.read(); // Clear the input
  
  Serial.println("\nStarting calibration process...");
  Serial.println("Robot will now move forward slowly to detect black line");
  Serial.println("Make sure robot will cross a BLACK line during calibration");
  Serial.println("Calibrating in 3...");
  delay(1000);
  Serial.println("2...");
  delay(1000);
  Serial.println("1...");
  delay(1000);
  Serial.println("GO! Moving forward for calibration...");
  
  // Start calibration
  calibrateSensors();
}

void loop() {
  if (!calibrated) {
    // Continue calibration if not finished
    if (millis() - calibrationStartTime < calibrationDuration) {
      readRawSensors();
      updateCalibration();
      moveForward(70); // Slow forward movement
    } else {
      // Calibration complete
      stopMotors();
      calculateThresholds();
      calibrated = true;
      
      Serial.println("\n=== CALIBRATION COMPLETE ===");
      Serial.println("Threshold values calculated:");
      for (int i = 0; i < 8; i++) {
        Serial.print("Sensor A");
        Serial.print(i);
        Serial.print(": Min=");
        Serial.print(sensorMin[i]);
        Serial.print(" Max=");
        Serial.print(sensorMax[i]);
        Serial.print(" Threshold=");
        Serial.println(threshold[i]);
      }
      Serial.println("\nNow displaying calibrated sensor values (0=White, 1=Black)");
      Serial.println("Format: [A0 A1 A2 A3 A4 A5 A6 A7]");
      Serial.println("----------------------------------------");
      delay(2000);
    }
  } else {
    // Normal operation - read and display calibrated values
    readRawSensors();
    applyCalibration();
    displaySensorValues();
    delay(100); // Update every 100ms
  }
}

// Read all 8 analog sensors
void readRawSensors() {
  for (int i = 0; i < 8; i++) {
    rawValue[i] = analogRead(sensorPins[i]);
  }
}

// Update min/max values during calibration
void updateCalibration() {
  for (int i = 0; i < 8; i++) {
    if (rawValue[i] < sensorMin[i]) {
      sensorMin[i] = rawValue[i];
    }
    if (rawValue[i] > sensorMax[i]) {
      sensorMax[i] = rawValue[i];
    }
  }
}

// Calculate thresholds based on min/max values
void calculateThresholds() {
  for (int i = 0; i < 8; i++) {
    // Threshold = (min + max) / 2
    threshold[i] = (sensorMin[i] + sensorMax[i]) / 2;
  }
}

// Apply calibration to get 0/1 values
void applyCalibration() {
  for (int i = 0; i < 8; i++) {
    if (rawValue[i] < threshold[i]) {
      calibratedValue[i] = 1; // Black line (lower reflection)
    } else {
      calibratedValue[i] = 0; // White surface (higher reflection)
    }
  }
}

// Display sensor values in 0/1 format
void displaySensorValues() {
  Serial.print("[");
  for (int i = 0; i < 8; i++) {
    Serial.print(calibratedValue[i]);
    if (i < 7) Serial.print(" ");
  }
  Serial.print("]");
  
  // Optional: Show raw values for debugging
  Serial.print("  Raw: [");
  for (int i = 0; i < 8; i++) {
    Serial.print(rawValue[i]);
    if (i < 7) Serial.print(" ");
  }
  Serial.println("]");
}

// Calibration routine
void calibrateSensors() {
  calibrationStartTime = millis();
  
  // Reset min/max values
  for (int i = 0; i < 8; i++) {
    sensorMin[i] = 1023;
    sensorMax[i] = 0;
  }
  
  // Read initial values to populate min/max
  for (int i = 0; i < 50; i++) {
    readRawSensors();
    updateCalibration();
    delay(10);
  }
}

// Motor control functions
void moveForward(int speed) {
  analogWrite(7,70);
  analogWrite(9,70);
  digitalWrite(motorLeftForward, HIGH);
  digitalWrite(motorLeftBackward, LOW);
  digitalWrite(motorRightForward, HIGH);
  digitalWrite(motorRightBackward, LOW);
}

void stopMotors() {
  analogWrite(7,0);
  analogWrite(9,0);
  digitalWrite(motorLeftForward, LOW);
  digitalWrite(motorLeftBackward, LOW);
  digitalWrite(motorRightForward, LOW);
  digitalWrite(motorRightBackward, LOW);
}
