import sys
import serial
from PyQt5 import QtWidgets, QtCore

PORT = 'COM17'
BAUD = 9600
NUM_SENSORS = 10


# -------- SERIAL THREAD --------
class SerialThread(QtCore.QThread):
    data_received = QtCore.pyqtSignal(list)
    text_received = QtCore.pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self.ser = serial.Serial(PORT, BAUD, timeout=1)
        self.running = True

    def run(self):
        while self.running:
            try:
                line = self.ser.readline().decode().strip()

                if not line:
                    continue

                # Calibration / text
                if not line[0].isdigit():
                    self.text_received.emit(line)
                    continue

                # Sensor data
                values = line.split()

                if len(values) == NUM_SENSORS:
                    self.data_received.emit(values)

            except:
                pass

    def stop(self):
        self.running = False
        self.ser.close()


# -------- MAIN UI --------
class SensorUI(QtWidgets.QWidget):
    def __init__(self):
        super().__init__()

        self.setWindowTitle("Fast Arduino Dashboard")
        self.setGeometry(200, 200, 900, 350)

        self.layout = QtWidgets.QVBoxLayout()

        self.status = QtWidgets.QLabel("Starting...")
        self.layout.addWidget(self.status)

        # Circles
        self.circle_layout = QtWidgets.QHBoxLayout()
        self.circles = []

        for _ in range(NUM_SENSORS):
            lbl = QtWidgets.QLabel()
            lbl.setFixedSize(40, 40)
            lbl.setStyleSheet(self.style("yellow"))
            self.circles.append(lbl)
            self.circle_layout.addWidget(lbl)

        self.layout.addLayout(self.circle_layout)

        self.setLayout(self.layout)

        # Thread
        self.thread = SerialThread()
        self.thread.data_received.connect(self.update_sensors)
        self.thread.text_received.connect(self.update_text)
        self.thread.start()

    def style(self, color):
        return f"""
        background-color: {color};
        border-radius: 20px;
        border: 1px solid black;
        """

    def update_text(self, text):
        self.status.setText(text)

    def update_sensors(self, values):
        self.status.setText("Running...")

        for i, v in enumerate(values):
            if v == '1':
                self.circles[i].setStyleSheet(self.style("blue"))
            else:
                self.circles[i].setStyleSheet(self.style("yellow"))

    def closeEvent(self, event):
        self.thread.stop()
        self.thread.quit()
        self.thread.wait()
        event.accept()


if __name__ == "__main__":
    app = QtWidgets.QApplication(sys.argv)
    window = SensorUI()
    window.show()
    sys.exit(app.exec_())
